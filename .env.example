# Supabase (frontend)
VITE_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
# NOTE: Keep this value on a single line (no line breaks), otherwise Supabase CLI may fail to parse `.env`.
VITE_SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>

# App URL (for QR code generation)
VITE_APP_URL=https://www.sparkstage55.com

# Midtrans (Client Key only - Server Key must be set in Supabase Edge Function Secrets)
VITE_MIDTRANS_CLIENT_KEY=<YOUR_MIDTRANS_CLIENT_KEY>
VITE_MIDTRANS_IS_PRODUCTION=false

# Production keys (uncomment when ready to go live)
# VITE_MIDTRANS_CLIENT_KEY=<YOUR_MIDTRANS_PROD_CLIENT_KEY>
# VITE_MIDTRANS_IS_PRODUCTION=true

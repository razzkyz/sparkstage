# Frontend / Vite env
# Use these in local `.env.local` and in frontend hosting such as Vercel.

VITE_SUPABASE_URL=<YOUR_SUPABASE_URL>
# Keep this value on a single line.
VITE_SUPABASE_ANON_KEY=<YOUR_SUPABASE_ANON_KEY>
VITE_APP_URL=http://localhost:5173
# Internal repo flag only. `false` loads sandbox Jokul Checkout JS, `true` loads production JS.
VITE_DOKU_IS_PRODUCTION=false

# Frontend production example
# VITE_APP_URL=https://www.sparkstage55.com
# VITE_DOKU_IS_PRODUCTION=true

# Supabase Edge Function secrets
# Do not put these in frontend hosting env.
# Set them with `supabase secrets set ...` or in the Supabase dashboard.
#
# DOKU_CLIENT_ID=<YOUR_DOKU_CLIENT_ID>
# DOKU_SECRET_KEY=<YOUR_DOKU_SECRET_KEY>
# Internal repo flag only. `false` selects sandbox API, `true` selects production API.
# DOKU_IS_PRODUCTION=false
# Comma-separated checkout whitelist. Keep launch scope intentionally narrow.
# Example: DOKU_PAYMENT_METHOD_TYPES=VIRTUAL_ACCOUNT_BNI,ONLINE_TO_OFFLINE_INDOMARET,ONLINE_TO_OFFLINE_ALFA
# DOKU_PAYMENT_METHOD_TYPES=
# PUBLIC_APP_URL=http://localhost:5173
# Comma-separated allowed browser origins for callback and CORS validation.
# APP_ALLOWED_ORIGINS=http://localhost:5173,https://www.sparkstage55.com
